# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=gestion_alquileres

# JWT Configuration
JWT_SECRET=super-secret-key-change-in-production-min-32-chars-long
JWT_EXPIRATION=7d

# Application Configuration
PORT=3000
NODE_ENV=development

# MC4/SIP Bolivia – QR Payments
MC4_AUTH_URL=https://sip.mc4.com.bo:8443/autenticacion/v1/generarToken
MC4_QR_URL=https://sip.mc4.com.bo:8443/api/v1/generaQr
MC4_STATUS_URL=https://sip.mc4.com.bo:8443/api/v1/estadoTransaccion
MC4_API_KEY_AUTH=your-api-key-auth
MC4_API_KEY_SERVICIO=your-api-key-servicio
MC4_USERNAME=your-mc4-username
MC4_PASSWORD=your-mc4-password
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MC4_CALLBACK_SECRET=your-callback-secret
