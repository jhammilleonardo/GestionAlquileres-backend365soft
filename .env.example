# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=gestion_alquileres

# JWT Configuration
JWT_SECRET=super-secret-key-change-in-production-min-32-chars-long
JWT_EXPIRATION=7d

# Application Configuration
PORT=3000
NODE_ENV=development

# MC4/SIP Bolivia – QR Payments
MC4_AUTH_URL=https://sip.mc4.com.bo:8443/autenticacion/v1/generarToken
MC4_QR_URL=https://sip.mc4.com.bo:8443/api/v1/generaQr
MC4_STATUS_URL=https://sip.mc4.com.bo:8443/api/v1/estadoTransaccion
MC4_API_KEY_AUTH=your-api-key-auth
MC4_API_KEY_SERVICIO=your-api-key-servicio
MC4_USERNAME=your-mc4-username
MC4_PASSWORD=your-mc4-password
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MC4_CALLBACK_SECRET=your-callback-secret

# pgAdmin (UI para PostgreSQL) — http://localhost:5050
PGADMIN_EMAIL=admin@365soft.com
PGADMIN_PASSWORD=admin365

# Dev Seed — credenciales del tenant "demo" (solo NODE_ENV=development)
DEV_SEED_EMAIL=admin@365soft.com
DEV_SEED_PASSWORD=Admin365!

# CORS — lista de orígenes permitidos separados por coma (producción: dominio real)
FRONTEND_URLS=http://localhost:4200,http://localhost:4201

# ── Stripe (EE.UU. y Guatemala — métodos: stripe, ach) ────────────────────────
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Obtener en: https://dashboard.stripe.com/webhooks (después de crear el endpoint)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── PayPal (EE.UU. — método: paypal) ─────────────────────────────────────────
# Crear app en: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret
# Producción: https://api-m.paypal.com
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
# Obtener en: https://developer.paypal.com/dashboard/webhooks/sandbox
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# ── PayU (Guatemala y Honduras — métodos: payu, tarjeta) ─────────────────────
# Obtener en: https://developers.payulatam.com — Panel de pruebas
PAYU_MERCHANT_ID=your_payu_merchant_id
PAYU_API_KEY=your_payu_api_key
PAYU_API_LOGIN=your_payu_api_login
PAYU_ACCOUNT_ID=your_payu_account_id
# Producción: https://api.payulatam.com/payments-api/4.0/service.cgi
PAYU_BASE_URL=https://sandbox.api.payulatam.com/payments-api/4.0/service.cgi

# ── Storage (default local, listo para S3) ─────────────────────────────────────
# Opciones: local | s3
STORAGE_DRIVER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=
# Expiración (segundos) para URLs firmadas privadas en S3
AWS_SIGNED_URL_EXPIRES_SECONDS=300
AWS_PUBLIC_SIGNED_URL_EXPIRES_SECONDS=3600
