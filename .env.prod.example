# ─────────────────────────────────────────────────────────────────────────────
# Despliegue manual en VPS — copiar a .env.prod y rellenar.
# NO commitear .env.prod (debe estar en .gitignore).
# Genera secretos fuertes con:  openssl rand -base64 48
# ─────────────────────────────────────────────────────────────────────────────

# Dominio y correo para el certificado SSL (Caddy)
APP_DOMAIN=gestionalquileres.acmanalytics.online
ACME_EMAIL=jhammilleonardo@gmail.com

# Ruta a la carpeta del frontend (hermana de esta). Ajustar si difiere.
FRONTEND_CONTEXT=../GestionAlquileres-frontend365soft

# ── Base de datos (Postgres en Docker) ──────────────────────────────────────
DB_USERNAME=gestion_app
DB_PASSWORD=CAMBIAR_por_secreto_real
DB_DATABASE=gestion_alquileres

# ── Seguridad / JWT ─────────────────────────────────────────────────────────
JWT_SECRET=CAMBIAR_min_32_chars_aleatorios_openssl_rand_base64_48
JWT_EXPIRATION=7d

# CORS: dominio(s) reales del frontend (sin barra final, sin localhost)
FRONTEND_URLS=https://gestionalquileres.acmanalytics.online

# TLS lo termina Caddy (el proxy), no Node
TRUST_PROXY=true
TLS_TERMINATED_BY_PROXY=true
HTTPS_ENABLED=false

# ── Almacenamiento de archivos (local en disco, sin S3 por ahora) ───────────
STORAGE_DRIVER=local
ALLOW_LOCAL_STORAGE_IN_PRODUCTION=true

# ── Logs ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_AGGREGATION_ENABLED=true

# ── Sentry del frontend (opcional, se hornea en el build) ───────────────────
FRONTEND_SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# Lo de abajo solo se valida si NODE_ENV=production. Con NODE_ENV=staging
# (como está fijado en docker-compose.prod.yml) NO es obligatorio, pero se deja
# listo por si más adelante activas monitoring/SendGrid/S3 reales.
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_POLICY_ACK=true
SECRET_ROTATION_POLICY_ACK=true
PROVISIONING_RUNBOOK_ACK=true
POSTGRES_BACKUP_ENABLED=true
MONITORING_PROVIDER=logger
LIFECYCLE_NOTIFICATION_PROVIDER=stub
ALLOW_NOTIFICATION_STUB_IN_PRODUCTION=true
SWAGGER_ENABLED=false
