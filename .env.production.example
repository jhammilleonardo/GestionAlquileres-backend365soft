# Copiar a .env.production o al gestor de secretos del proveedor.
# No commitear secretos reales.

NODE_ENV=production
TYPEORM_LOGGING=false
PORT=3000

# Database
DB_HOST=prod-postgres.internal
DB_PORT=5432
DB_USERNAME=gestion_alquileres_app
DB_PASSWORD=replace-with-real-secret
DB_DATABASE=gestion_alquileres

# Security
JWT_SECRET=replace-with-64-plus-random-chars
JWT_EXPIRATION=7d
FRONTEND_URLS=https://app.365soft.example,https://admin.365soft.example
SWAGGER_ENABLED=false
SWAGGER_FAIL_FAST=true
TRUST_PROXY=true
TLS_TERMINATED_BY_PROXY=true
HTTPS_ENABLED=false
RATE_LIMIT_POLICY_ACK=true
SECRET_ROTATION_POLICY_ACK=true

# Monitoring / logs
MONITORING_PROVIDER=webhook
MONITORING_WEBHOOK_URL=https://monitoring-provider.example/intake
MONITORING_API_KEY=replace-with-monitoring-token
MONITORING_SERVICE_NAME=365soft-backend
MONITORING_ENVIRONMENT=production
MONITORING_TIMEOUT_MS=5000
LOG_AGGREGATION_ENABLED=true

# Lifecycle external notifications
# Email real con SendGrid; WhatsApp real puede usar twilio o whatsapp_cloud.
LIFECYCLE_NOTIFICATION_PROVIDER=sendgrid
SENDGRID_API_KEY=replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@365soft.example
SENDGRID_FROM_NAME=365Soft
NOTIFICATION_TIMEOUT_MS=7000

# Twilio WhatsApp, si se usa LIFECYCLE_NOTIFICATION_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+10000000000

# WhatsApp Cloud API, si se usa LIFECYCLE_NOTIFICATION_PROVIDER=whatsapp_cloud
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_GRAPH_VERSION=v19.0

# MC4/SIP Bolivia QR
MC4_ENABLED=true
MC4_AUTH_URL=https://sip.mc4.com.bo:8443/autenticacion/v1/generarToken
MC4_QR_URL=https://sip.mc4.com.bo:8443/api/v1/generaQr
MC4_STATUS_URL=https://sip.mc4.com.bo:8443/api/v1/estadoTransaccion
MC4_API_KEY_AUTH=replace-with-real-key
MC4_API_KEY_SERVICIO=replace-with-real-key
MC4_USERNAME=replace-with-real-user
MC4_PASSWORD=replace-with-real-password
MC4_CALLBACK_SECRET=replace-with-64-plus-random-chars

# Stripe
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.paypal.com
PAYPAL_WEBHOOK_ID=

# PayU
PAYU_MERCHANT_ID=
PAYU_API_KEY=
PAYU_API_LOGIN=
PAYU_ACCOUNT_ID=
PAYU_BASE_URL=https://api.payulatam.com/payments-api/4.0/service.cgi

# Storage
STORAGE_DRIVER=s3
AWS_REGION=us-east-1
AWS_BUCKET_NAME=365soft-prod-private-files
AWS_ACCESS_KEY_ID=replace-with-iam-access-key
AWS_SECRET_ACCESS_KEY=replace-with-iam-secret
AWS_SIGNED_URL_EXPIRES_SECONDS=300
AWS_PUBLIC_SIGNED_URL_EXPIRES_SECONDS=3600
ALLOW_LOCAL_STORAGE_IN_PRODUCTION=false

# Operations
POSTGRES_BACKUP_ENABLED=true
PROVISIONING_RUNBOOK_ACK=true
STRICT_CONFIG_VALIDATION=true
