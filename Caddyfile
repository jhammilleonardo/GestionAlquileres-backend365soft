# Router HTTP interno. El TLS lo termina Nginx Proxy Manager (NPM), que reenvía
# el tráfico de gestionalquileres.acmanalytics.online a este Caddy en el puerto 80.
# Caddy solo reparte: /api -> backend NestJS, el resto -> frontend Angular.

:80 {
	encode zstd gzip

	# /api/* -> backend. handle_path ELIMINA el prefijo /api,
	# así /api/acme/admin/x llega al backend como /acme/admin/x
	handle_path /api/* {
		reverse_proxy api:3000
	}

	# Todo lo demás -> frontend Angular (nginx)
	handle {
		reverse_proxy frontend:80
	}
}
